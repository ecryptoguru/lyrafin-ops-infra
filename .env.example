# ============================================================
# Lyrafin Ops Infrastructure — Environment Template
# Copy to .env and fill with real values for local dev (or use Doppler CLI)
# NEVER commit real secrets to git.
# Production deploys must pass scripts/preflight-prod.sh; the local placeholder
# values below are intentionally rejected by that preflight.
# ============================================================

# --- General ---
TZ=Etc/UTC

# ============================================================
# EMAIL PROFILE (listmonk)
# ============================================================

# listmonk app
LISTMONK_PORT=9001
LISTMONK_ADMIN_USER=admin
LISTMONK_ADMIN_PASSWORD=change-me

# listmonk database
LISTMONK_DB_USER=listmonk
LISTMONK_DB_PASSWORD=change-me
LISTMONK_DB_NAME=listmonk

# Mailpit (local SMTP testing)
MAILPIT_SMTP_PORT=8025

# SES production settings (set when deploying to Contabo via Doppler)
# These are used by docker-compose.prod.yml to configure listmonk SMTP.
# SES_SMTP_HOST=email-smtp.us-east-1.amazonaws.com
# SES_SMTP_PORT=587
# SES_SMTP_USER=<ses-smtp-user>
# SES_SMTP_PASSWORD=<ses-smtp-password>
# LISTMONK_SMTP_TLS_TYPE=STARTTLS
# LISTMONK_SMTP_AUTH_PROTOCOL=login
# LISTMONK_SMTP_HELLO_HOST=newsletter.lyrafinai.com

# Lyrafin app integration
LISTMONK_BASE_URL=http://localhost:9001
LISTMONK_API_USER=local
LISTMONK_API_TOKEN=local-dev-token
LISTMONK_BLOG_LIST_ID=1
LISTMONK_TRANSACTIONAL_TEMPLATE_ID=1

# ============================================================
# SOCIAL PROFILE (Postiz)
# ============================================================

# Note: port 5000 conflicts with macOS AirPlay Receiver — use 5050 for local dev
POSTIZ_PORT=5050
POSTIZ_MAIN_URL=http://localhost:5050
POSTIZ_FRONTEND_URL=http://localhost:5050
POSTIZ_NEXT_PUBLIC_BACKEND_URL=http://localhost:5050/api
POSTIZ_JWT_SECRET=change-me-to-a-long-random-string
POSTIZ_DISABLE_REGISTRATION=false

# Postiz database
POSTIZ_DB_USER=postiz-user
POSTIZ_DB_PASSWORD=change-me
POSTIZ_DB_NAME=postiz-db-local

# Temporal database
TEMPORAL_DB_USER=temporal
TEMPORAL_DB_PASSWORD=change-me

# Social provider OAuth credentials (register at Step 10)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# Postiz OpenAI (optional, for AI features)
POSTIZ_OPENAI_API_KEY=

# Lyrafin app integration
POSTIZ_BASE_URL=http://localhost:5050
POSTIZ_API_TOKEN=local-dev-token

# ============================================================
# CONVERT PROFILE (MarkItDown API)
# ============================================================

MARKITDOWN_PORT=9100
MARKITDOWN_API_KEY=local-dev-token
MARKITDOWN_MAX_FILE_SIZE_MB=50
MARKITDOWN_TIMEOUT_SECONDS=120

# Azure Document Intelligence (for OCR/table mode)
AZURE_DOC_INTEL_ENDPOINT=
AZURE_DOC_INTEL_KEY=

# Lyrafin app integration
MARKITDOWN_BASE_URL=http://localhost:9100

# ============================================================
# PRODUCTION ONLY (Contabo deployment)
# ============================================================

# Domain configuration
# NEWSLETTER_DOMAIN=newsletter.lyrafinai.com
# SOCIAL_DOMAIN=social.lyrafinai.com
# CONVERT_DOMAIN=convert.lyrafinai.com

# Email from
# EMAIL_FROM_ADDRESS=admin@lyrafinai.com
# EMAIL_FROM_NAME=Lyrafin AI
